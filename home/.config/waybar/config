{
  "layer": "top",
  "position": "top",
  "height": 24,

  "margin-top": 0,
  "margin-left": 450,
  "margin-right": 450,
  "margin-bottom": 0,

  "reload_style_on_change": true,

  "modules-left": ["niri/window"],
  "modules-center": ["clock"],
  "modules-right": ["custom/weather", "backlight", "pulseaudio", "battery", "tray"],

  "niri/window": {
    "format": "{title}  ",
    "max-length": 45,
    "separate-outputs": false
  },

  "tray": {
    "icon-size": 14,
    "spacing": 8
  },

  "battery": {
    "interval": 10,
    "states": {
        "warning": 30,
        "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "format-plugged": "󰚥 {capacity}%",
    "format-icons": ["󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
    "tooltip": true
  },

  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["󱩌", "󱉕", "󱉓"],
    "tooltip": true,
    "on-scroll-up": "brightnessctl set 5%+",
    "on-scroll-down": "brightnessctl set 5%-"
  },

  "custom/weather": {
    "format": " 󰖐 {} ",
    "exec": "curl -s 'wttr.in/?format=%t' 2>/dev/null",
    "interval": 900
  },

  "pulseaudio": {
    "format": "  {volume}% ",
    "on-click": "pavucontrol"
  },

  "clock": {
    "format": " {:%a, %b %d | %I:%M%p} ",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode"          : "month",
      "mode-mon-col"  : 3,
      "weeks-pos"     : "right",
      "on-scroll"     : 1,
      "format": {
        "months":     "<b>{}</b>",
        "days":       "<b>{}</b>",
        "weeks":      "<b>W{}</b>",
        "weekdays":   "<b>{}</b>",
        "today":      "<b><u>{}</u></b>"
      }
    },
    "actions":  {
      "on-click-right": "mode",
      "on-scroll-up": "tz_up",
      "on-scroll-down": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
}
